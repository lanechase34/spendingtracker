# Env
ENVIRONMENT=development

# Lucee Admin, Guard Extensions for local/test
OTHER_EXTENSIONS=,CED6227E-0F49-6367-A68D21AACA6B07E8;version=1.0.0.7,37C61C0A-5D7E-4256-8572639BE0CF5838;version=3.0.0.14

# Config
CFCONFIG_ADMINPASSWORD=commandbox
LUCEE_ADMIN_ENABLED=true
INSPECTTEMPLATE=always
IMAGEMAGICK=/usr/local/bin/magick

# Web
HTTP_HOST=0.0.0.0
HTTP_PORT=8082
REQUESTTIMEOUT=300

# Java
OS=linux
JAVAHEAP=4096

# Database
DB_GRAMMAR=PostgresGrammar@qb
DB_SCHEMA=public
DB_DATABASE=spendingtracker_db
DB_BUNDLENAME=org.postgresql.jdbc
DB_BUNDLEVERSION=42.7.9
DB_CLASS=org.postgresql.Driver
DB_DRIVER=postgresql
DB_HOST=spendingtracker_db
DB_PORT=5432
DB_USERNAME=docker_user
DB_PASSWORD=docker1234

# Email
EMAIL_SERVER=
EMAIL_PORT=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_TLS=
EMAIL_SSL=
EMAIL_SPOOL=

# Secrets
REINITKEY=
JWT_SECRET=
ENCRYPTIONKEY=generateSecretKey(algorithm="AES", keysize=256)