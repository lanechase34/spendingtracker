{
    "app":{
        "cfengine":"boxlang@1.13.0+50"
    },
    "cfconfig":{
        "file":".cfconfig.json"
    },
    "jvm":{
        "heapSize":"${JAVAHEAP}",
        "minHeapSize":"${JAVAHEAP}",
        "javaVersion":"openjdk21_jre_x64_${OS}_hotspot_jdk-21.0.10+7",
        "args":"-Duser.timezone=UTC"
    },
    "name":"SpendingTracker",
    "openbrowser":"false",
    "openBrowserUrl":"http://${HTTP_HOST}:${HTTP_PORT}",
    "runwar":{
        "UndertowOptions":{
            "MAX_ENTITY_SIZE":52428800
        }
    },
    "scripts":{
        "onServerInitialInstall":"install bx-compat-cfml,bx-esapi,bx-image,bx-mail,bx-postgresql"
    },
    "trayEnable":"false",
    "web":{
        "host":"${HTTP_HOST}",
        "rewrites":{
            "enable":"true"
        },
        "directoryBrowsing":"false",
        "http":{
            "enable":"true",
            "port":"${HTTP_PORT}"
        },
        "rules":[
            "warm-up-server(urls={'/warmup'}, requestStrategy=queue, async=false, timeoutSeconds=300)",
            "path-prefix-nocase(/lucee/) -> ip-access-control[default-allow=false, acl={'127.0.0.* allow', '::1 allow'}, failure-status=404]",
            "path(/WebSocket.cfc) -> done",
            "regex-nocase('.*(box\\.json|Dockerfile|cfconfig\\.json|server\\.json)') or path-suffix-nocase(.env) or path-suffix-nocase(.md) or path-suffix-nocase(.cfc) or path-prefix-nocase(/.well-known/) -> set-error(404)",
            "regex-nocase('.*\\.(webp|css|js|ico|woff|woff2|ttf|svg)$') or regex-nocase('.*\\?v=[a-zA-Z0-9]{10}$') -> set(attribute='%{o,Cache-Control}', value='public, max-age=25552000')"
        ],
        "maxRequests":"50",
        "webroot":"",
        "useProxyForwardedIP":"true",
        "websocket":{
            "enable":"true",
            "listener":"WebSocket.cfc"
        }
    }
}
