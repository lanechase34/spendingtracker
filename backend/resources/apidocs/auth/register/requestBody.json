{
    "required": true,
    "content": {
        "application/x-www-form-urlencoded": {
            "schema": {
                "type": "object",
                "required": ["email", "password", "salary", "monthlyTakeHome"],
                "properties": {
                    "email": { "type": "string", "format": "email", "example": "user@example.com" },
                    "password": { "type": "string", "format": "password", "example": "secretpassword" },
                    "salary": { "type": "number", "example": 75000 },
                    "monthlyTakeHome": { "type": "number", "example": 4500 }
                }
            }
        }
    }
}
