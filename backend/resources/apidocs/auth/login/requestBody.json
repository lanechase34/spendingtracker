{
    "required": true,
    "content": {
        "application/x-www-form-urlencoded": {
            "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                    "email": { "type": "string", "format": "email", "example": "test1@gmail.com" },
                    "password": { "type": "string", "format": "password", "example": "secretpassword" },
                    "rememberMe": { "type": "boolean", "example": true }
                }
            }
        }
    }
}
