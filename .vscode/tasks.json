{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Format Backend",
            "type": "shell",
            "command": "box run-script format",
            "group": {
                "kind": "build"
            },
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "detail": "Format Backend code using CF Formatter"
        },
        {
            "label": "Format Frontend",
            "type": "shell",
            "command": "npm run-script format",
            "group": {
                "kind": "build"
            },
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "detail": "Format Frontend code using Prettier"
        },
        {
            "label": "Lint ts, tsx",
            "type": "shell",
            "command": "npm run-script lint",
            "group": {
                "kind": "build"
            },
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "detail": "Lint *.ts and *.tsx files"
        },
        {
            "label": "Typecheck ts, tsx",
            "type": "shell",
            "command": "npm run typecheck",
            "group": {
                "kind": "build"
            },
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "detail": "Typecheck *.ts and *.tsx files"
        },
        {
            "label": "Github Actions Test Backend",
            "type": "shell",
            "command": "act -W '.github/workflows/test-backend.yml' -P ubuntu-24.04=ghcr.io/catthehacker/ubuntu:act-24.04 --rm --pull=false",
            "group": {
                "kind": "test"
            },
            "detail": "Runs the ./github/workflows/test-backend.yml locally",
            "isBackground": true
        },
        {
            "label": "Github Actions Test Frontend",
            "type": "shell",
            "command": "act -W '.github/workflows/test-frontend.yml' -P ubuntu-24.04=ghcr.io/catthehacker/ubuntu:act-24.04 --rm --pull=false",
            "group": {
                "kind": "test"
            },
            "detail": "Runs the ./github/workflows/test-frontend.yml locally",
            "isBackground": true
        },
        {
            "label": "Github Actions Test Housekeeping",
            "type": "shell",
            "command": "act -W '.github/workflows/housekeeping.yml' -P ubuntu-24.04=ghcr.io/catthehacker/ubuntu:act-24.04 --rm --pull=false",
            "group": {
                "kind": "test"
            },
            "detail": "Runs the ./github/workflows/housekeeping.yml locally",
            "isBackground": true
        },
        {
            "label": "Start Server",
            "dependsOn": ["Start Backend", "Start Frontend"],
            "dependsOrder": "parallel",
            "problemMatcher": []
        },
        {
            "label": "Start Backend",
            "type": "shell",
            "command": "box server start",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "presentation": {
                "panel": "dedicated",
                "reveal": "always",
                "focus": false
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Start Frontend",
            "type": "shell",
            "command": "npm start",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "presentation": {
                "panel": "dedicated",
                "reveal": "always",
                "focus": false
            },
            "isBackground": true,
            "problemMatcher": []
        }
    ]
}
